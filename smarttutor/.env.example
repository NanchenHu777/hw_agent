# SmartTutor - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============ 选择使用的模型提供商 ============
# 可选值: "openai", "deepseek", "azure", "hkust_azure"
ACTIVE_PROVIDER=hkust_azure

# ============ OpenAI 配置 ============
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============ DeepSeek 配置（低成本选择） ============
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============ HKUST Azure API 配置 ============
HKUST_AZURE_API_KEY=your_hkust_azure_api_key_here
HKUST_AZURE_ENDPOINT=https://hkust.azure-api.net
HKUST_AZURE_DEPLOYMENT_NAME=gpt-4o-mini
HKUST_AZURE_API_VERSION=2025-02-01-preview

# ============ 标准 Azure OpenAI 配置 ============
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============ 应用设置 ============
DEBUG=true
SESSION_TIMEOUT=3600
